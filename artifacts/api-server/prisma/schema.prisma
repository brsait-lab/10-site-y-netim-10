generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id             String    @id @default(uuid())
  name           String
  address        String    @default("")
  adminId        String    @default("") @map("admin_id")
  joinCode       String?   @map("join_code")
  settlementType String    @default("site") @map("settlement_type")
  bankName       String?   @map("bank_name")
  accountHolder  String?   @map("account_holder")
  iban           String?
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("sites")
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                String
  siteId              String    @map("site_id")
  status              String    @default("active")
  phone               String    @default("")
  unitNo              String?   @map("unit_no")
  block               String?
  tower               String?
  villaNo             String?   @map("villa_no")
  floor               String?
  officeNo            String?   @map("office_no")
  plates              String[]
  businessName        String?   @map("business_name")
  businessCategory    String?   @map("business_category")
  businessDescription String?   @map("business_description")
  businessAddress     String?   @map("business_address")
  businessHours       String?   @map("business_hours")
  latitude            Float?
  longitude           Float?
  consentGiven        Boolean   @default(false) @map("consent_given")
  consentAt           DateTime? @map("consent_at")
  consentVersion      String?   @map("consent_version")
  sessionVersion      Int       @default(0) @map("session_version")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([siteId])
  @@index([siteId, deletedAt])
  @@index([siteId, status])
  @@map("users")
}

model AdminTransfer {
  id            String   @id @default(uuid())
  siteId        String   @map("site_id")
  oldAdminId    String   @map("old_admin_id")
  newAdminId    String   @map("new_admin_id")
  reason        String?
  transferredAt DateTime @default(now()) @map("transferred_at")

  @@map("admin_transfers")
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  fromUserId String   @map("from_user_id")
  fromName   String   @map("from_name")
  toRoles    String[] @map("to_roles")
  toUserIds  String[] @map("to_user_ids")
  siteId     String   @map("site_id")
  readBy     String[] @map("read_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([siteId, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  @@unique([notificationId, userId])
  @@index([notificationId])
  @@index([userId])
  @@map("notification_reads")
}

model Payment {
  id            String    @id @default(uuid())
  siteId        String    @map("site_id")
  title         String
  amount        Float
  dueDate       String    @map("due_date")
  type          String
  description   String?
  targetBlocks  String[]  @default([]) @map("target_blocks")
  targetUserIds String[]  @default([]) @map("target_user_ids")
  createdBy     String    @default("") @map("created_by")
  cancelledAt   DateTime? @map("cancelled_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([siteId, createdAt(sort: Desc)])
  @@index([siteId, cancelledAt])
  @@map("payments")
}

model UserPayment {
  id         String    @id @default(uuid())
  paymentId  String    @map("payment_id")
  userId     String    @map("user_id")
  siteId     String    @map("site_id")
  status     String    @default("pending")
  paidAt     DateTime? @map("paid_at")
  note       String?
  receiptUrl String?   @map("receipt_url")

  @@index([paymentId])
  @@index([userId])
  @@index([siteId, status])
  @@map("user_payments")
}

model Chat {
  id         String    @id @default(uuid())
  siteId     String    @map("site_id")
  title      String
  status     String    @default("open")
  createdBy  String    @map("created_by")
  closedBy   String?   @map("closed_by")
  closedAt   DateTime? @map("closed_at")
  deletedFor String[]  @map("deleted_for")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([siteId, createdAt(sort: Desc)])
  @@map("chats")
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String   @map("chat_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([chatId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  fromId    String   @map("from_id")
  fromName  String   @map("from_name")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chatId, createdAt(sort: Asc)])
  @@map("messages")
}

model Package {
  id              String    @id @default(uuid())
  siteId          String    @map("site_id")
  recipientUserId String    @map("recipient_user_id")
  recipientName   String    @map("recipient_name")
  senderInfo      String    @map("sender_info")
  description     String
  status          String    @default("received")
  receivedAt      DateTime  @default(now()) @map("received_at")
  deliveredAt     DateTime? @map("delivered_at")

  @@index([siteId, receivedAt(sort: Desc)])
  @@index([recipientUserId])
  @@map("packages")
}

model VendorCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vendor_categories")
}

model Vendor {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  category    String
  description String   @default("")
  phone       String   @default("")
  address     String   @default("")
  latitude    Float?
  longitude   Float?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([status])
  @@map("vendors")
}

model VendorRequest {
  id          String    @id @default(uuid())
  siteId      String    @map("site_id")
  requestedBy String    @map("requested_by")
  vendorId    String?   @map("vendor_id")
  title       String
  description String
  status      String    @default("pending")
  assignedAt  DateTime? @map("assigned_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([siteId, createdAt(sort: Desc)])
  @@index([vendorId])
  @@map("vendor_requests")
}
