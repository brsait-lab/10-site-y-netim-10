generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id        String   @id @default(uuid())
  name      String
  address   String   @default("")
  adminId   String   @default("") @map("admin_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sites")
}

model User {
  id                  String   @id @default(uuid())
  name                String
  email               String   @unique
  passwordHash        String   @map("password_hash")
  role                String
  siteId              String   @map("site_id")
  status              String   @default("pending")
  phone               String   @default("")
  unitNo              String?  @map("unit_no")
  plates              String[]
  businessName        String?  @map("business_name")
  businessCategory    String?  @map("business_category")
  businessDescription String?  @map("business_description")
  businessAddress     String?  @map("business_address")
  latitude            Float?
  longitude           Float?
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  fromUserId String   @map("from_user_id")
  fromName   String   @map("from_name")
  toRoles    String[] @map("to_roles")
  toUserIds  String[] @map("to_user_ids")
  siteId     String   @map("site_id")
  readBy     String[] @map("read_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

model NotificationRead {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  userId         String   @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

model Payment {
  id          String   @id @default(uuid())
  siteId      String   @map("site_id")
  title       String
  amount      Float
  dueDate     String   @map("due_date")
  type        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("payments")
}

model UserPayment {
  id        String    @id @default(uuid())
  paymentId String    @map("payment_id")
  userId    String    @map("user_id")
  siteId    String    @map("site_id")
  status    String    @default("pending")
  paidAt    DateTime? @map("paid_at")

  @@map("user_payments")
}

model Chat {
  id         String    @id @default(uuid())
  siteId     String    @map("site_id")
  title      String
  status     String    @default("open")
  createdBy  String    @map("created_by")
  closedBy   String?   @map("closed_by")
  closedAt   DateTime? @map("closed_at")
  deletedFor String[]  @map("deleted_for")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("chats")
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String   @map("chat_id")
  userId   String   @map("user_id")
  joinedAt DateTime @default(now()) @map("joined_at")

  @@unique([chatId, userId])
  @@map("chat_participants")
}

model Message {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  fromId    String   @map("from_id")
  fromName  String   @map("from_name")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Package {
  id              String    @id @default(uuid())
  siteId          String    @map("site_id")
  recipientUserId String    @map("recipient_user_id")
  recipientName   String    @map("recipient_name")
  senderInfo      String    @map("sender_info")
  description     String
  status          String    @default("received")
  receivedAt      DateTime  @default(now()) @map("received_at")
  deliveredAt     DateTime? @map("delivered_at")

  @@map("packages")
}

model VendorCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vendor_categories")
}

model Vendor {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  category    String
  description String   @default("")
  phone       String   @default("")
  address     String   @default("")
  latitude    Float?
  longitude   Float?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("vendors")
}

model VendorRequest {
  id          String    @id @default(uuid())
  siteId      String    @map("site_id")
  requestedBy String    @map("requested_by")
  vendorId    String?   @map("vendor_id")
  title       String
  description String
  status      String    @default("pending")
  assignedAt  DateTime? @map("assigned_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("vendor_requests")
}
