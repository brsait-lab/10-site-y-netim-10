{
  "expo": {
    "name": "Site Yönetim",
    "slug": "site-yonetim",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "siteyonetim",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#166534"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.betasite.siteyonetim"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "80a949d3-aa76-4c32-adcf-9fa01e7e46ee"
      }
    }
  }
}
